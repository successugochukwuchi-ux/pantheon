rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // 1. HELPERS & GLOBAL SAFETY
    // ===============================================================
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // High-priority admin check
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "successugochukwuchi@gmail.com" || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('level', '1') in ["3", "4"]
      );
    }

    function isLevel2() {
      return isSignedIn() && (
        request.auth.token.email == "successugochukwuchi@gmail.com" ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('level', '1') in ["2", "3", "4"]
      );
    }

    // ===============================================================
    // 2. ENTITY VALIDATORS
    // ===============================================================

    function isValidCourse(data) {
      return data.code is string && 
             data.title is string &&
             data.semester in ['1st', '2nd'];
    }

    function isValidNote(data) {
      return data.courseId is string &&
             data.title is string &&
             data.type in ['lecture', 'punch', 'past_question', 'cbt'] &&
             data.authorId == request.auth.uid;
    }

    function isValidQuestionSheet(data) {
      return data.courseId is string &&
             data.semester in ['1st', '2nd'] &&
             data.year is string &&
             data.authorId == request.auth.uid;
    }

    function isValidQuestion(data) {
      return data.sheetId is string &&
             data.courseId is string &&
             data.text is string &&
             data.incorrectAnswers is list &&
             data.authorId == request.auth.uid;
    }

    // ===============================================================
    // 3. COLLECTIONS
    // ===============================================================

    match /users/{userId} {
      allow read: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && 
                      incoming().level == '1' && 
                      incoming().isActivated == false;
      allow update: if (isOwner(userId) && 
                        incoming().diff(existing()).affectedKeys().hasOnly(['username', 'theme', 'referredBy'])) || 
                      isAdmin();
    }

    match /courses/{courseId} {
      allow read, list: if isSignedIn();
      allow create: if isAdmin() && isValidCourse(incoming());
      allow update: if isAdmin() && isValidCourse(incoming());
      allow delete: if isAdmin();
    }

    match /notes/{noteId} {
      allow read, list: if isSignedIn();
      allow create: if isAdmin() && isValidNote(incoming());
      allow update: if isAdmin() && isValidNote(incoming());
      allow delete: if isAdmin();
      
      match /videoQuestions/{questionId} {
        allow read, list: if isSignedIn();
        allow write: if isAdmin();
      }
    }

    match /questionSheets/{sheetId} {
      allow read, list: if isSignedIn();
      allow create: if isAdmin() && isValidQuestionSheet(incoming());
      allow update: if isAdmin() && isValidQuestionSheet(incoming());
      allow delete: if isAdmin();
    }

    match /questions/{questionId} {
      allow read, list: if isSignedIn();
      allow create: if isAdmin() && isValidQuestion(incoming());
      allow update: if isAdmin() && isValidQuestion(incoming());
      allow delete: if isAdmin();
    }

    match /activationCodes/{code} {
      allow read, list: if isLevel2();
      allow write: if isLevel2();
      allow delete: if isAdmin();
    }

    match /verificationRequests/{requestId} {
      allow read, list: if isLevel2();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /news/{newsId} { allow read, list: if isSignedIn(); allow write: if isAdmin(); }
    match /system/{docId} { allow read, list: if true; allow write: if isAdmin(); }
    match /cbt_sessions/{sessionId} {
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow read, list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }
    match /discussions/{messageId} { 
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }
    match /notifications/{notificationId} { 
      allow read, list, update: if isSignedIn() && resource.data.userId == request.auth.uid; 
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
    match /announcements/{announcementId} { allow read, list: if isSignedIn(); allow write: if isAdmin(); }
    match /reports/{reportId} { allow read, write: if isAdmin(); allow create: if isSignedIn(); }
    match /diagnostics/{docId} { allow read, write: if true; }

    // Chat rules
    match /chats/{chatId} {
      allow read, list: if isSignedIn() && (isAdmin() || request.auth.uid in resource.data.uids);
      allow create: if isSignedIn() && request.auth.uid in incoming().uids;
      allow update: if isSignedIn() && (isAdmin() || request.auth.uid in resource.data.uids);
      
      match /messages/{messageId} {
        allow read, list: if isSignedIn() && (isAdmin() || request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.uids);
        allow create: if isSignedIn() && (isAdmin() || (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.uids && incoming().senderUid == request.auth.uid));
        allow delete: if isAdmin() || (isSignedIn() && resource.data.senderUid == request.auth.uid);
      }
    }

    match /friendships/{friendshipId} {
      allow read, list: if isSignedIn() && (isAdmin() || request.auth.uid in resource.data.uids);
      allow create: if isSignedIn() && request.auth.uid in incoming().uids;
      allow delete: if isSignedIn() && (isAdmin() || request.auth.uid in resource.data.uids);
    }

    match /friend_requests/{requestId} {
      allow read, list: if isSignedIn() && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);
      allow create: if isSignedIn() && incoming().fromUid == request.auth.uid;
      allow update, delete: if isSignedIn() && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);
    }

    match /progress/{progressId} {
      allow read, list: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn() && incoming().uid == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.uid == request.auth.uid || isAdmin());
    }
  }
}
