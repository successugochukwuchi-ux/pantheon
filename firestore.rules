rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // 1. HELPERS & GLOBAL SAFETY
    // ===============================================================
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // High-priority admin check - handles initial email token
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "successugochukwuchi@gmail.com" || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('level', '1') in ["3", "4"])
      );
    }

    function isLevel2() {
      return isSignedIn() && (
        request.auth.token.email == "successugochukwuchi@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('level', '1') in ["2", "3", "4"])
      );
    }

    // ===============================================================
    // 2. SYSTEM & CONFIG
    // ===============================================================
    match /system/{docId} {
      allow read, list: if isSignedIn();
      allow write: if isAdmin();
    }

    // ===============================================================
    // 3. USER PROFILES
    // ===============================================================
    match /users/{userId} {
      // Allow user to read their own profile or others (for search/friends)
      allow read: if isSignedIn();
      // Allow listing users only for admins (security improvement)
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
    }

    // ===============================================================
    // 4. CHATS & COMMUNICATION
    // ===============================================================
    match /chats/{chatId} {
      allow read, list: if isSignedIn() && (isAdmin() || request.auth.uid in resource.data.get('uids', []));
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.get('uids', []);
      allow update: if isSignedIn() && (isAdmin() || request.auth.uid in resource.data.get('uids', []));
      
      match /messages/{messageId} {
        allow read, list: if isSignedIn() && (isAdmin() || request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.get('uids', []));
        allow create: if isSignedIn() && (isAdmin() || (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.get('uids', []) && request.resource.data.senderUid == request.auth.uid));
        allow delete: if isAdmin() || (isSignedIn() && resource.data.senderUid == request.auth.uid);
      }
    }

    match /friendships/{friendshipId} {
      allow read, list: if isSignedIn() && (isAdmin() || request.auth.uid in resource.data.get('uids', []));
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.get('uids', []);
      allow delete: if isSignedIn() && (isAdmin() || request.auth.uid in resource.data.get('uids', []));
    }

    match /friend_requests/{requestId} {
      allow read, list: if isSignedIn() && (resource.data.get('fromUid', '') == request.auth.uid || resource.data.get('toUid', '') == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.get('fromUid', '') == request.auth.uid;
      allow update, delete: if isSignedIn() && (resource.data.get('fromUid', '') == request.auth.uid || resource.data.get('toUid', '') == request.auth.uid);
    }

    // ===============================================================
    // 5. ACADEMIC ENGINE
    // ===============================================================
    match /courses/{courseId} {
      allow read, list: if isSignedIn();
      allow write: if isAdmin();
    }

    match /notes/{noteId} {
      allow read, list: if isSignedIn();
      allow write: if isAdmin();
      
      match /videoQuestions/{questionId} {
        allow read, list: if isSignedIn();
        allow write: if isAdmin();
      }
    }

    match /activationCodes/{code} {
      allow read, list: if isLevel2(); // Restrict to Level 2 and above
      allow create, update: if isLevel2();
      allow delete: if isAdmin();
    }

    // ===============================================================
    // 6. UTILITY & FALLBACK
    // ===============================================================
    match /news/{newsId} { allow read, list: if isSignedIn(); allow write: if isAdmin(); }
    match /verificationRequests/{requestId} { 
      allow read, list: if isLevel2(); 
      allow create: if isSignedIn(); 
      allow update, delete: if isAdmin(); 
    }
    match /questionSheets/{sheetId} { 
      allow read, list: if isSignedIn(); 
      allow write: if isAdmin(); 
    }
    match /questions/{questionId} { 
      allow read, list: if isSignedIn(); 
      allow write: if isAdmin(); 
    }
    match /cbt_sessions/{sessionId} { 
      allow create: if isSignedIn(); 
      allow read, list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid); 
    }
    match /discussions/{messageId} { allow read, list, create, update, delete: if isSignedIn(); }
    match /notifications/{notificationId} { allow read, list, update, delete: if isSignedIn() && resource.data.userId == request.auth.uid; }
    match /announcements/{announcementId} { allow read, list: if isSignedIn(); allow write: if isAdmin(); }
    match /reports/{reportId} { allow read, write: if isAdmin(); allow create: if isSignedIn(); }
    match /diagnostics/{docId} { allow read, write: if true; }

    // Final safety fallback
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
