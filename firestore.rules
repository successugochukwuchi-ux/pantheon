rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Master Admin Override - Highest Priority
    // ===============================================================
    // Alwasys allow the admin using UID or Email (via safe .get() method)
    match /{document=**} {
      allow read, write: if request.auth != null && (
        request.auth.uid == "o9YQZ2G2DTfIk1wwGeXAh1LCsxP2" || 
        request.auth.token.get("email", "") == "successugochukwuchi@gmail.com"
      );
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return request.auth != null && (
        request.auth.uid == "o9YQZ2G2DTfIk1wwGeXAh1LCsxP2" ||
        request.auth.token.get("email", "") == "successugochukwuchi@gmail.com"
      );
    }

    function isLevel2Admin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.level == "2";
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && (
        isAdmin() || 
        (request.auth.uid == userId && (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['username', 'department', 'academicLevel', 'mobileNumber', 'theme', 'photoURL', 'fcmToken']) ||
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['referralCount']) && request.resource.data.referralCount == resource.data.referralCount + 1) ||
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isActivated', 'activatedViaPromo', 'fcmToken']) && resource.data.isActivated == false && request.resource.data.isActivated == true && request.resource.data.activatedViaPromo == true)
        ))
      );
    }

    match /chats/{chatId} {
      allow read, write: if isAuthenticated() && (isAdmin() || request.auth.uid in resource.data.uids);
      allow create: if isAuthenticated();
      
      match /messages/{messageId} {
        allow read, write: if isAuthenticated();
      }
    }

    match /system/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /notes/{noteId} {
      allow read: if true;
      allow write: if isAdmin();
      
      match /videoQuestions/{questionId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    match /news/{newsId} {
      allow read, list: if true;
      allow write: if isAdmin();
    }

    match /activationCodes/{code} {
      allow read: if true;
      allow create, delete: if isAdmin() || isLevel2Admin();
      allow update: if isAuthenticated();
    }

    match /verificationRequests/{requestId} {
      allow read, write: if isAdmin() || (isAuthenticated() && resource.data.uid == request.auth.uid);
      allow create: if isAuthenticated();
    }

    match /questionSheets/{sheetId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /questions/{questionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /cbt_sessions/{sessionId} {
      allow read, write: if isAuthenticated();
    }

    match /discussions/{messageId} {
      allow read, write: if isAuthenticated();
    }

    match /friend_requests/{requestId} {
      allow read, write: if isAuthenticated();
    }

    match /friendships/{friendshipId} {
      allow read, write: if isAuthenticated();
    }

    match /notifications/{notificationId} {
      allow read, list, update, delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAdmin();
    }

    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /reports/{reportId} {
      allow read, write: if isAdmin();
      allow create: if isAuthenticated();
    }
  }
}
